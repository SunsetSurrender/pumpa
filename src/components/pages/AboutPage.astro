---
import { Picture } from 'astro:assets';
import gaugeImage from '../../assets/gauge.jpg';
import gaugeWide from '../../assets/gauge-wide.jpg';
import { useT, type Locale } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useT(locale);
---
<section class="hero-band about-hero">
  <div class="hero-media" aria-hidden="true">
    <Picture
      src={gaugeWide}
      formats={['webp']}
      fallbackFormat="webp"
      width={1920}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      alt=""
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>
  <div class="hero-scrim" aria-hidden="true"></div>
  <div class="container about-hero-inner">
    <p class="mono-label">{t.about.eyebrow}</p>
    <h1>{t.about.h1}</h1>
    <p class="about-lede">{t.about.lede}</p>
    <dl class="about-stats">
      {t.about.stats.map((stat) => (
        <div class="stat">
          <dt class="stat-label">{stat.label}</dt>
          <dd class="stat-n">{stat.n}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<div class="container about-body">
  <div class="about-intro" data-reveal>
    <div class="prose">
      <p set:html={t.about.p1} />
    </div>
    <figure class="about-figure">
      <Picture
        src={gaugeImage}
        formats={['webp']}
        fallbackFormat="webp"
        width={800}
        widths={[480, 800]}
        sizes="(max-width: 900px) 100vw, 360px"
        alt={t.about.imgAlt}
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>

  <div class="about-features">
    <div class="feature-block" data-reveal>
      <h2>{t.about.h2Privacy}</h2>
      <p>{t.about.pPrivacy}</p>
    </div>
    <div class="feature-block" data-reveal>
      <h2>{t.about.h2Units}</h2>
      <p>{t.about.pUnits}</p>
    </div>
  </div>

  <div class="prose about-contact" data-reveal>
    <h2 id="contact">{t.about.h2Contact}</h2>
    <p set:html={t.about.pContact} />
  </div>
</div>

<style>
  /* ---- opening band: display-scale headline over the scrimmed gauge shot ---- */
  .about-hero-inner{ padding-top: 5.5rem; padding-bottom: 4rem; }
  .about-hero .mono-label{ color: var(--hero-text-mid); }
  .about-hero h1{
    color: var(--hero-text-hi);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05; letter-spacing: -0.02em;
    max-width: 22ch;
    margin: 0.75rem 0 1rem;
  }
  .about-lede{
    color: var(--hero-text-mid);
    font-size: 1.125rem; line-height: 1.6;
    max-width: 40rem; margin: 0 0 3rem;
  }
  .about-stats{
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem; margin: 0; max-width: 46rem;
    border-top: 1px solid rgba(179, 170, 161, 0.3);
    padding-top: 2rem;
  }
  .stat{ display: flex; flex-direction: column-reverse; margin: 0; }
  .stat-n{
    margin: 0;
    font-family: 'Share Tech Mono', monospace; font-variant-numeric: tabular-nums;
    font-size: clamp(2rem, 4vw, 2.75rem); line-height: 1.1;
    color: var(--hero-accent);
  }
  .stat-label{ font-size: 0.875rem; line-height: 1.4; color: var(--hero-text-mid); margin-top: 0.25rem; }

  /* ---- body ---- */
  .about-body{ padding-top: 3.5rem; }
  .about-intro{
    display: grid; grid-template-columns: minmax(0, 1fr) 360px;
    gap: 3rem; align-items: start;
  }
  .about-figure{ margin: 0; }
  .about-figure img{
    width: 100%; height: auto; display: block;
    border-radius: 14px;
    border: 1px solid var(--reading-border);
    box-shadow: 0 16px 40px -24px rgba(42, 37, 33, 0.5);
  }

  .about-features{
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 3rem 0;
    max-width: 60rem;
  }
  .feature-block{
    background: var(--reading-surface);
    border: 1px solid var(--reading-border);
    border-left: 3px solid var(--reading-link);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .feature-block h2{
    font-size: 1.25rem; margin: 0 0 0.5rem;
    color: var(--reading-text);
  }
  .feature-block p{ margin: 0; font-size: 0.9375rem; line-height: 1.7; color: var(--reading-text-mid); }

  .about-contact{ margin-bottom: 2rem; }

  @media (max-width: 900px){
    .about-hero-inner{ padding-top: 3.5rem; padding-bottom: 3rem; }
    .about-intro{ grid-template-columns: 1fr; gap: 2rem; }
    .about-figure{ max-width: 26rem; }
    .about-features{ grid-template-columns: 1fr; }
  }
  @media (max-width: 640px){
    .about-stats{ grid-template-columns: 1fr; gap: 1rem; }
  }
</style>
