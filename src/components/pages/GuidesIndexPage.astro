---
import { getCollection } from 'astro:content';
import { useT, localeHref, type Locale } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useT(locale);

const posts = (await getCollection('guides', ({ id, data }) => !data.draft && id.startsWith(locale + '/')))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = posts;

const counts = {
  all: posts.length,
  economy: posts.filter((p) => p.data.category === 'economy').length,
  costs: posts.filter((p) => p.data.category === 'costs').length,
};

const dateLocale = locale === 'en' ? 'en-GB' : locale;
const fmt = (d: Date) =>
  d.toLocaleDateString(dateLocale, { day: '2-digit', month: 'short', year: 'numeric' });
const slugOf = (id: string) => id.split('/')[1];
const catLabel = (c: keyof typeof t.guides.categories) => t.guides.categories[c];
---
<div class="page-head">
  <p class="mono-label">{t.guides.eyebrow}</p>
  <h1>{t.guides.h1}</h1>
  <p class="lede">{t.guides.lede}</p>
</div>

<section class="hub-intro" data-reveal>
  <h2>{t.guides.introTitle}</h2>
  <p>{t.guides.introBody}</p>
</section>

<div class="guide-filter" id="guideFilter" hidden>
  <span class="gf-label" id="guideFilterLabel">{t.guides.filterLabel}</span>
  <div class="gf-pills" role="group" aria-labelledby="guideFilterLabel">
    <button type="button" data-filter="all" aria-pressed="true">{t.guides.categories.all} <span class="gf-n">({counts.all})</span></button>
    <button type="button" data-filter="economy" aria-pressed="false">{t.guides.categories.economy} <span class="gf-n">({counts.economy})</span></button>
    <button type="button" data-filter="costs" aria-pressed="false">{t.guides.categories.costs} <span class="gf-n">({counts.costs})</span></button>
  </div>
</div>

{featured && (
  <a class="site-card guide-card guide-featured" href={localeHref(locale, `/guides/${slugOf(featured.id)}/`)} data-category={featured.data.category}>
    <div class="guide-meta">
      <span class="guide-cat">{catLabel(featured.data.category)}</span>
      <time datetime={featured.data.pubDate.toISOString()}>{fmt(featured.data.pubDate)}</time>
    </div>
    <h2>{featured.data.title}</h2>
    <p>{featured.data.description}</p>
    <span class="guide-more">{t.guides.readMore}</span>
  </a>
)}

<div class="guides-list">
  {rest.map((post) => (
    <a class="site-card guide-card" href={localeHref(locale, `/guides/${slugOf(post.id)}/`)} data-category={post.data.category}>
      <div class="guide-meta">
        <span class="guide-cat">{catLabel(post.data.category)}</span>
        <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
      </div>
      <h2>{post.data.title}</h2>
      <p>{post.data.description}</p>
      <span class="guide-more">{t.guides.readMore}</span>
    </a>
  ))}
</div>

<div class="ad-slot"><span>{t.chrome.adLabel}</span></div>

<script is:inline>
  /* Category filter: pure progressive enhancement. Server renders the
     full list; without JS this row stays hidden and everything is
     visible. Filtering toggles [hidden] — no layout animation, no CLS. */
  (() => {
    const bar = document.getElementById('guideFilter');
    if (!bar) return;
    const cards = document.querySelectorAll('[data-category]');
    if (!cards.length) return;
    bar.hidden = false;
    const buttons = bar.querySelectorAll('button[data-filter]');
    bar.addEventListener('click', (ev) => {
      const btn = ev.target.closest('button[data-filter]');
      if (!btn) return;
      const filter = btn.dataset.filter;
      buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
      cards.forEach((card) => { card.hidden = filter !== 'all' && card.dataset.category !== filter; });
    });
  })();
</script>

<style>
  .hub-intro{
    max-width: 46rem;
    margin: 2.5rem 0 2rem;
    padding: 1.5rem;
    background: var(--reading-surface);
    border: 1px solid var(--reading-border);
    border-left: 3px solid var(--reading-link);
    border-radius: 12px;
  }
  .hub-intro h2{
    font-size: 1.25rem; margin: 0 0 0.5rem;
    color: var(--reading-text);
  }
  .hub-intro p{ margin: 0; font-size: 0.9375rem; line-height: 1.7; color: var(--reading-text-mid); }

  .guide-card{
    display: block; text-decoration: none; color: inherit;
    background: var(--reading-surface);
    border-color: var(--reading-border);
    box-shadow: none;
    transition: border-color .15s, transform .15s;
  }
  .guide-card:hover{ border-color: var(--reading-link); }

  .guide-filter{
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    margin: 0 0 1.25rem;
  }
  .gf-label{ font-size: 0.875rem; font-weight: 600; color: var(--reading-text-mid); }
  .gf-pills{ display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .gf-pills button{
    min-height: 44px; padding: 8px 16px;
    background: transparent;
    border: 1px solid var(--reading-border); border-radius: 999px;
    font-family: inherit; font-size: 0.875rem; font-weight: 600;
    color: var(--reading-text-mid); cursor: pointer;
    transition: color .15s, border-color .15s, background .15s;
  }
  .gf-pills button:hover{ border-color: var(--reading-link); color: var(--reading-text); }
  .gf-pills button[aria-pressed="true"]{
    background: var(--reading-link);
    border-color: var(--reading-link);
    color: var(--reading-bg);
  }
  .gf-n{ font-weight: 400; }

  .guide-featured{ margin-bottom: 18px; padding: 2rem; }
  .guide-featured h2{ font-size: 1.5rem; max-width: 34rem; }
  .guide-featured p{ max-width: 46rem; }

  .guides-list{
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .guide-meta{
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    font-size: 0.8125rem;
    color: var(--reading-text-mid); margin-bottom: 0.75rem;
  }
  .guide-cat{
    border: 1px solid var(--reading-link); border-radius: 999px;
    padding: 2px 10px; color: var(--reading-link); font-weight: 600;
  }
  .guide-card h2{
    margin: 0 0 0.5rem; font-size: 1.25rem; line-height: 1.3;
    color: var(--reading-text);
  }
  .guide-card p{ margin: 0 0 1rem; font-size: 0.9375rem; line-height: 1.6; color: var(--reading-text-mid); }
  .guide-more{
    font-size: 0.9375rem; font-weight: 600;
    color: var(--reading-link);
  }
  @media (max-width: 760px){
    .guides-list{ grid-template-columns: 1fr; }
    .guide-featured{ padding: 1.5rem; }
  }
</style>
