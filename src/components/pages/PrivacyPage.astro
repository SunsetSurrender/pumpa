---
import { useT, type Locale } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useT(locale);
---
<div class="page-head">
  <p class="mono-label">{t.privacy.eyebrow}</p>
  <h1>{t.privacy.h1}</h1>
</div>

<div class="prose">
  <p set:html={t.privacy.p1} />
  <h2>{t.privacy.h2Practice}</h2>
  <p>{t.privacy.pPractice}</p>
  <h2>{t.privacy.h2Third}</h2>
  <p>{t.privacy.pThird}</p>
  <p class="mono-label">{t.privacy.updated}</p>
</div>
