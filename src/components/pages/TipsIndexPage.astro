---
import { getCollection } from 'astro:content';
import { useT, localeHref, type Locale } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useT(locale);

const posts = (await getCollection('tips', ({ id, data }) => !data.draft && id.startsWith(locale + '/')))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateLocale = locale === 'en' ? 'en-GB' : locale;
const fmt = (d: Date) =>
  d.toLocaleDateString(dateLocale, { day: '2-digit', month: 'short', year: 'numeric' });
const slugOf = (id: string) => id.split('/')[1];
---
<div class="page-head">
  <p class="mono-label">{t.tips.eyebrow}</p>
  <h1>{t.tips.h1}</h1>
  <p class="lede">{t.tips.lede}</p>
</div>

<div class="tips-list">
  {posts.map((post) => (
    <a class="site-card tip-card" href={localeHref(locale, `/tips/${slugOf(post.id)}/`)}>
      <div class="tip-meta">
        <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
        {post.data.tags.map((tag) => <span class="tip-tag">{tag}</span>)}
      </div>
      <h2>{post.data.title}</h2>
      <p>{post.data.description}</p>
      <span class="tip-more">{t.tips.readMore}</span>
    </a>
  ))}
</div>

<style>
  .tips-list{
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 18px; margin-top: 28px;
  }
  .tip-card{
    display: block; text-decoration: none; color: inherit;
    background: var(--reading-surface);
    border-color: var(--reading-border);
    box-shadow: none;
    transition: border-color .15s;
  }
  .tip-card:hover{ border-color: var(--reading-link); }
  .tip-meta{
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    font-size: 0.8125rem;
    color: var(--reading-text-mid); margin-bottom: 0.75rem;
  }
  .tip-tag{
    border: 1px solid var(--reading-border); border-radius: 999px;
    padding: 2px 10px; color: var(--reading-text-mid);
  }
  .tip-card h2{
    margin: 0 0 0.5rem; font-size: 1.25rem; line-height: 1.3;
    color: var(--reading-text);
  }
  .tip-card p{ margin: 0 0 1rem; font-size: 0.9375rem; line-height: 1.6; color: var(--reading-text-mid); }
  .tip-more{
    font-size: 0.9375rem; font-weight: 600;
    color: var(--reading-link);
  }
  @media (max-width: 760px){
    .tips-list{ grid-template-columns: 1fr; }
  }
</style>
