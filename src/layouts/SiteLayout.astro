---
import '../styles/site.css';

interface Props {
  title: string;
  description: string;
  /** Set false on pages that bring their own <main> wrapper (the calculator). */
  container?: boolean;
  /** "reading" = warm paper surface for long-form pages (tips/about/privacy). */
  surface?: 'default' | 'reading';
}

const { title, description, container = true, surface = 'default' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/calculator/', label: 'Calculator' },
  { href: '/tips/', label: 'Tips' },
  { href: '/about/', label: 'About' },
];

const current = Astro.url.pathname;
const isCurrent = (href) =>
  href === '/' ? current === '/' : current === href || current.startsWith(href);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/theme.css">
  <script is:inline>
    /* Theme boot — runs before paint to avoid a flash of wrong theme.
       Order: saved choice → prefers-contrast → prefers-color-scheme. */
    (() => {
      let theme = null;
      try { theme = localStorage.getItem('pumpaTheme'); } catch {}
      if (theme !== 'dark' && theme !== 'light' && theme !== 'contrast'){
        theme = matchMedia('(prefers-contrast: more)').matches ? 'contrast'
          : matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      document.documentElement.dataset.theme = theme;
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700&family=Figtree:wght@400;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-nav">
    <div class="container">
      <a class="nav-brand" href="/" aria-label="Pumpa home">
        <svg class="nav-gauge" viewBox="0 0 32 32" width="30" height="30" aria-hidden="true">
          <path d="M6 22 A 11 11 0 1 1 26 22" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <line x1="16" y1="21" x2="22.5" y2="11.5" stroke="var(--accent)" stroke-width="3" stroke-linecap="round"/>
          <circle cx="16" cy="21" r="2.6" fill="var(--accent)"/>
        </svg>
        <span class="nav-word">Pumpa</span>
      </a>
      <nav aria-label="Site">
        <ul class="nav-links">
          {navItems.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <button type="button" id="themeToggle" class="theme-toggle">
        <span aria-hidden="true">◐</span>
        <span id="themeToggleLabel">Theme</span>
      </button>
    </div>
  </header>

  <script is:inline>
    (() => {
      const names = { dark: 'Dark', light: 'Light', contrast: 'High contrast' };
      const order = ['dark', 'light', 'contrast'];
      const btn = document.getElementById('themeToggle');
      const label = document.getElementById('themeToggleLabel');
      const sync = () => {
        const current = document.documentElement.dataset.theme;
        label.textContent = names[current] || 'Theme';
        btn.setAttribute('aria-label', 'Change theme, current: ' + (names[current] || current));
      };
      btn.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme;
        const next = order[(order.indexOf(current) + 1) % order.length];
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('pumpaTheme', next); } catch {}
        sync();
      });
      sync();
    })();
  </script>

  <main class:list={['site-main', { 'surface-reading': surface === 'reading' }]} id="main">
    {container ? <div class="container"><slot /></div> : <slot />}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-col footer-about">
        <p class="footer-brand">Pumpa</p>
        <p>A fuel &amp; commute cost tracker that lives in your browser — nothing uploaded, nothing to sign up for.</p>
      </div>
      <div class="footer-col">
        <h2>Product</h2>
        <ul>
          <li><a href="/calculator/">Calculator</a></li>
          <li><a href="/tips/">Tips</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h2>Legal</h2>
        <ul>
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/cookies/">Cookies</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <span>© Pumpa. Made for people who'd rather keep their fuel money.</span>
      </div>
    </div>
  </footer>
</body>
</html>
