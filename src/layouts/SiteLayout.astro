---
import '../styles/site.css';
import { locales, localeNames, useT, localeHref, stripLocale, type Locale } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  /** Set false on pages that bring their own <main> wrapper (the calculator). */
  container?: boolean;
  /** "reading" = warm paper surface for long-form pages (tips/about/privacy). */
  surface?: 'default' | 'reading';
  /**
   * Locale -> path for hreflang links. Defaults to this page's path in every
   * locale. Pages whose translation doesn't exist (untranslated tips articles)
   * pass only the locales that are real.
   */
  alternates?: Partial<Record<Locale, string>>;
  /**
   * Locale -> path the language switcher navigates to. Defaults to
   * `alternates`, then to a locale-prefixed version of the current path.
   * Article pages point missing translations at that locale's /tips/ index.
   */
  switchTargets?: Partial<Record<Locale, string>>;
}

const {
  title, description,
  locale = 'en',
  container = true,
  surface = 'default',
  alternates,
  switchTargets,
} = Astro.props;

const t = useT(locale);
const { path: basePath } = stripLocale(Astro.url.pathname);

const defaultAlternates = Object.fromEntries(
  locales.map((l) => [l, localeHref(l, basePath)])
) as Record<Locale, string>;

const hreflangs = alternates ?? defaultAlternates;
const switcher = { ...defaultAlternates, ...(alternates ?? {}), ...(switchTargets ?? {}) };

const navItems = [
  { href: localeHref(locale, '/'), label: t.chrome.nav.home, base: '/' },
  { href: localeHref(locale, '/calculator/'), label: t.chrome.nav.calculator, base: '/calculator/' },
  { href: localeHref(locale, '/tips/'), label: t.chrome.nav.tips, base: '/tips/' },
  { href: localeHref(locale, '/about/'), label: t.chrome.nav.about, base: '/about/' },
];

const isCurrent = (base: string) =>
  base === '/' ? basePath === '/' : basePath === base || basePath.startsWith(base);
---
<!doctype html>
<html lang={locale}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)}>
  {Object.entries(hreflangs).map(([l, path]) => (
    <link rel="alternate" hreflang={l} href={new URL(path, Astro.site)} />
  ))}
  {hreflangs.en && <link rel="alternate" hreflang="x-default" href={new URL(hreflangs.en, Astro.site)} />}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/theme.css">
  <script is:inline>
    /* Theme boot — runs before paint to avoid a flash of wrong theme.
       Order: saved choice → prefers-contrast → prefers-color-scheme. */
    (() => {
      let theme = null;
      try { theme = localStorage.getItem('pumpaTheme'); } catch {}
      if (theme !== 'dark' && theme !== 'light' && theme !== 'contrast'){
        theme = matchMedia('(prefers-contrast: more)').matches ? 'contrast'
          : matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      document.documentElement.dataset.theme = theme;
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700&family=Figtree:wght@400;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main">{t.chrome.skip}</a>
  <header class="site-nav">
    <div class="container">
      <a class="nav-brand" href={localeHref(locale, '/')} aria-label={t.chrome.brandHome}>
        <svg class="nav-gauge" viewBox="0 0 32 32" width="30" height="30" aria-hidden="true">
          <path d="M6 22 A 11 11 0 1 1 26 22" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <line x1="16" y1="21" x2="22.5" y2="11.5" stroke="var(--accent)" stroke-width="3" stroke-linecap="round"/>
          <circle cx="16" cy="21" r="2.6" fill="var(--accent)"/>
        </svg>
        <span class="nav-word">Pumpa</span>
      </a>
      <nav aria-label={t.chrome.navLabel}>
        <ul class="nav-links">
          {navItems.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.base) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <div class="nav-tools">
        <nav aria-label={t.chrome.langLabel}>
          <ul class="lang-switch">
            {locales.map((l) => (
              <li>
                <a
                  href={switcher[l]}
                  hreflang={l}
                  lang={l}
                  aria-current={l === locale ? 'true' : undefined}
                  aria-label={localeNames[l]}
                >{l.toUpperCase()}</a>
              </li>
            ))}
          </ul>
        </nav>
        <button
          type="button" id="themeToggle" class="theme-toggle"
          data-name-dark={t.chrome.theme.dark}
          data-name-light={t.chrome.theme.light}
          data-name-contrast={t.chrome.theme.contrast}
          data-change-label={t.chrome.theme.change}
        >
          <span aria-hidden="true">◐</span>
          <span id="themeToggleLabel">…</span>
        </button>
      </div>
    </div>
  </header>

  <script is:inline>
    (() => {
      const btn = document.getElementById('themeToggle');
      const label = document.getElementById('themeToggleLabel');
      const names = {
        dark: btn.dataset.nameDark, light: btn.dataset.nameLight, contrast: btn.dataset.nameContrast,
      };
      const order = ['dark', 'light', 'contrast'];
      const sync = () => {
        const current = document.documentElement.dataset.theme;
        label.textContent = names[current] || 'Theme';
        btn.setAttribute('aria-label', btn.dataset.changeLabel + ' ' + (names[current] || current));
      };
      btn.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme;
        const next = order[(order.indexOf(current) + 1) % order.length];
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('pumpaTheme', next); } catch {}
        sync();
      });
      sync();
    })();
  </script>

  <main class:list={['site-main', { 'surface-reading': surface === 'reading' }]} id="main">
    {container ? <div class="container"><slot /></div> : <slot />}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-col footer-about">
        <p class="footer-brand">Pumpa</p>
        <p>{t.chrome.footer.blurb}</p>
      </div>
      <div class="footer-col">
        <h2>{t.chrome.footer.product}</h2>
        <ul>
          <li><a href={localeHref(locale, '/calculator/')}>{t.chrome.nav.calculator}</a></li>
          <li><a href={localeHref(locale, '/tips/')}>{t.chrome.nav.tips}</a></li>
          <li><a href={localeHref(locale, '/about/')}>{t.chrome.nav.about}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h2>{t.chrome.footer.legal}</h2>
        <ul>
          <li><a href={localeHref(locale, '/privacy/')}>{t.chrome.footer.privacy}</a></li>
          <li><a href={localeHref(locale, '/cookies/')}>{t.chrome.footer.cookies}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <span>{t.chrome.footer.bottom}</span>
      </div>
    </div>
  </footer>
</body>
</html>
