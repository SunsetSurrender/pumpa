---
import '../styles/site.css';

interface Props {
  title: string;
  description: string;
  /** Set false on pages that bring their own <main> wrapper (the calculator). */
  container?: boolean;
}

const { title, description, container = true } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/calculator/', label: 'Calculator' },
  { href: '/tips/', label: 'Tips' },
  { href: '/about/', label: 'About' },
];

const current = Astro.url.pathname;
const isCurrent = (href) =>
  href === '/' ? current === '/' : current === href || current.startsWith(href);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  <slot name="head" />
</head>
<body>
  <header class="site-nav">
    <div class="container">
      <a class="nav-brand" href="/" aria-label="Pumpa home">
        <span class="nav-mark">P</span>
        <span class="nav-word">Pumpa</span>
      </a>
      <nav aria-label="Site">
        <ul class="nav-links">
          {navItems.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </header>

  <main class="site-main">
    {container ? <div class="container"><slot /></div> : <slot />}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-col">
        <h4>Pumpa</h4>
        <p>
          A fuel &amp; commute cost tracker that lives in your browser. Trip costs,
          fill-up logs and spending reports — stored on your device, never on a server.
        </p>
      </div>
      <div class="footer-col">
        <h4>Site</h4>
        <ul>
          <li><a href="/calculator/">Calculator</a></li>
          <li><a href="/tips/">Tips</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact &amp; legal</h4>
        <ul>
          <li><a href="/about/#contact">Contact</a></li>
          <li><a href="/privacy/">Privacy</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <span>© {new Date().getFullYear()} Pumpa</span>
        <span>All data stays on your device</span>
      </div>
    </div>
  </footer>
</body>
</html>
