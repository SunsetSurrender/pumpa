---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';

const latestTips = (await getCollection('tips', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<SiteLayout
  title="Pumpa — know what every trip really costs"
  description="Free fuel & commute cost calculator. Work out the fuel cost of any trip, log fill-ups, track spending — metric, US or UK units, any currency, all stored on your device."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="mono-label">Fuel · Commute · Cost</p>
      <h1>Know what every trip <em>really</em> costs.</h1>
      <p class="lede">
        Distance, consumption, fuel price — Pumpa turns them into a number you can
        act on. Log trips and fill-ups, watch monthly spending, switch freely between
        metric, US and UK units. No account, no upload: everything stays in your browser.
      </p>
      <div class="hero-actions">
        <a class="btn-link amber" href="/calculator/">Open the calculator</a>
        <a class="btn-link ghost" href="/tips/">Read the tips</a>
      </div>
    </div>
    <div class="hero-demo" aria-hidden="true">
      <div class="demo-panel">
        <div class="demo-label">Trip cost</div>
        <div class="demo-value">€12.43</div>
        <div class="demo-row"><span>70.5 km</span><span>·</span><span>3.4 L/100km</span><span>·</span><span>€1.777/L</span></div>
        <div class="demo-sub">vs your usual route <span class="demo-delta">+€0.58</span></div>
      </div>
    </div>
  </section>

  <h2 class="section-title">How it works</h2>
  <section class="steps">
    <div class="site-card step">
      <div class="step-num">01</div>
      <h3>Enter a trip</h3>
      <p>Distance, your car's consumption and the fuel price at the pump. Metric,
        US or UK — switching converts your numbers, it doesn't just relabel them.</p>
    </div>
    <div class="site-card step">
      <div class="step-num">02</div>
      <h3>See the cost</h3>
      <p>Fuel used and trip cost, instantly — plus the difference against a baseline
        route, so detours and shortcuts get an honest price tag.</p>
    </div>
    <div class="site-card step">
      <div class="step-num">03</div>
      <h3>Log &amp; learn</h3>
      <p>Save trips and fill-ups. Pumpa turns them into monthly spending, real
        consumption and cost-per-distance reports you can export as CSV or PDF.</p>
    </div>
  </section>

  <h2 class="section-title">From the tips</h2>
  <section class="tips-teaser">
    <div class="teaser-grid">
      {latestTips.map((post) => (
        <a class="site-card teaser-card" href={`/tips/${post.id}/`}>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
    <a class="btn-link ghost" href="/tips/">Browse all tips</a>
  </section>

  <h2 class="section-title">Pumpa Pro</h2>
  <section class="pro-strip site-card">
    <div class="pro-strip-copy">
      <h3>One unlock. Yours forever.</h3>
      <p>
        The calculator is free and stays free. Pro removes the history limits,
        unlocks the full PDF report and keeps the app ad-free — a one-time unlock,
        no subscription, right inside the calculator.
      </p>
    </div>
    <ul class="pro-strip-perks">
      <li>Unlimited trip &amp; fill-up history</li>
      <li>Full PDF report export</li>
      <li>No ads, ever</li>
    </ul>
  </section>
</SiteLayout>

<style>
  .hero{
    display: grid; grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 48px; align-items: center;
    padding: 72px 0 24px;
  }
  .hero h1{
    margin: 0.75rem 0 1rem;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.05; letter-spacing: -0.02em;
  }
  .hero h1 em{ font-style: normal; color: var(--accent); }
  .lede{ font-size: 1.125rem; line-height: 1.6; max-width: 34rem; margin: 0 0 2rem; }
  .hero-actions{ display: flex; gap: 12px; flex-wrap: wrap; }

  .demo-panel{
    background: linear-gradient(180deg, var(--lcd-bg), var(--lcd-bg-2));
    border: 1px solid var(--lcd-edge); border-radius: 14px;
    padding: 2rem 1.5rem;
    box-shadow: var(--lcd-halo);
  }
  .demo-label{
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem; letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--lcd-meta); margin-bottom: 0.5rem;
  }
  .demo-value{
    font-family: 'Share Tech Mono', monospace; font-variant-numeric: tabular-nums;
    font-size: clamp(3rem, 6vw, 5rem); line-height: 1.1;
    color: var(--lcd-value);
    text-shadow: var(--lcd-glow);
    margin-bottom: 0.75rem;
  }
  .demo-row{
    display: flex; gap: 0.5rem; flex-wrap: wrap;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8125rem; color: var(--lcd-meta); margin-bottom: 1rem;
  }
  .demo-sub{ font-size: 0.875rem; color: var(--lcd-meta); }
  .demo-delta{ font-family: 'Share Tech Mono', monospace; color: var(--negative); }

  .steps{ display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .step-num{
    color: var(--text-lo); font-size: 0.875rem; font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .step h3{ margin: 0 0 0.5rem; }
  .step p{ margin: 0; font-size: 1rem; line-height: 1.6; }

  .teaser-grid{
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 18px; margin-bottom: 20px;
  }
  .teaser-card{ display: block; text-decoration: none; transition: border-color .15s; }
  .teaser-card:hover{ border-color: var(--amber-dim); }
  .teaser-card h3{ margin: 0 0 0.5rem; font-size: 1.125rem; line-height: 1.35; }
  .teaser-card p{ margin: 0; font-size: 0.875rem; line-height: 1.6; color: var(--text-mid); }

  .pro-strip{
    display: grid; grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
    gap: 28px; align-items: center;
    margin-bottom: 8px;
  }
  .pro-strip h3{ margin: 0 0 0.5rem; }
  .pro-strip p{ margin: 0; font-size: 1rem; line-height: 1.6; }
  .pro-strip-perks{
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
    font-size: 0.9375rem; font-weight: 600; color: var(--positive);
  }
  .pro-strip-perks li::before{ content: '✓ '; color: var(--positive); }

  @media (max-width: 900px){
    .hero{ grid-template-columns: 1fr; gap: 32px; padding-top: 44px; }
    .hero-demo{ max-width: 420px; }
    .steps{ grid-template-columns: 1fr; }
    .teaser-grid{ grid-template-columns: 1fr; }
    .pro-strip{ grid-template-columns: 1fr; }
  }
</style>
